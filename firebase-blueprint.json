{
  "entities": {
    "Location": {
      "title": "Location",
      "description": "A coop or area where hens are kept",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Coop", "Free Range", "Barn"] },
        "capacity": { "type": "number" },
        "photoUrl": { "type": "string" }
      },
      "required": ["id", "name", "type", "capacity"]
    },
    "EggLog": {
      "title": "EggLog",
      "description": "A record of eggs collected",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "count": { "type": "number" },
        "locationId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "count", "locationId", "date"]
    },
    "Hen": {
      "title": "Hen",
      "description": "A record of an individual chicken",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "breed": { "type": "string" },
        "age": { "type": "number" },
        "locationId": { "type": "string" },
        "photoUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Healthy", "Sick", "Isolated", "Deceased"] }
      },
      "required": ["id", "name", "breed", "age", "locationId", "status"]
    },
    "FeedLog": {
      "title": "FeedLog",
      "description": "A record of feed consumption or purchase",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "quantity": { "type": "number" },
        "cost": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "locationId": { "type": "string" }
      },
      "required": ["id", "type", "quantity", "cost", "date", "locationId"]
    },
    "MedicationLog": {
      "title": "MedicationLog",
      "description": "A record of medication administered",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "henId": { "type": "string" },
        "medication": { "type": "string" },
        "dosage": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "henId", "medication", "dosage", "date"]
    },
    "SaleLog": {
      "title": "SaleLog",
      "description": "A record of eggs sold",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "quantity", "price", "date"]
    },
    "ChickBatch": {
      "title": "ChickBatch",
      "description": "A record of a batch of chicks being incubated",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "dateStarted": { "type": "string", "format": "date-time" },
        "expectedHatchDate": { "type": "string", "format": "date-time" },
        "count": { "type": "number" },
        "status": { "type": "string", "enum": ["Incubating", "Hatched", "Failed"] },
        "locationId": { "type": "string" },
        "notes": { "type": "string" },
        "hatchedCount": { "type": "number" },
        "perishedCount": { "type": "number" },
        "photoUrl": { "type": "string" },
        "chicks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "hatchDate": { "type": "string", "format": "date-time" },
              "gender": { "type": "string", "enum": ["Male", "Female", "Unknown"] },
              "photoUrl": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "dateStarted", "expectedHatchDate", "count", "status", "locationId"]
    }
  },
  "firestore": {
    "/users/{userId}/locations/{locationId}": {
      "schema": "Location",
      "description": "User's coops and locations"
    },
    "/users/{userId}/eggLogs/{logId}": {
      "schema": "EggLog",
      "description": "User's egg production records"
    },
    "/users/{userId}/hens/{henId}": {
      "schema": "Hen",
      "description": "User's individual chickens"
    },
    "/users/{userId}/feedLogs/{logId}": {
      "schema": "FeedLog",
      "description": "User's feed records"
    },
    "/users/{userId}/medicationLogs/{logId}": {
      "schema": "MedicationLog",
      "description": "User's medication records"
    },
    "/users/{userId}/saleLogs/{logId}": {
      "schema": "SaleLog",
      "description": "User's egg sales records"
    },
    "/users/{userId}/chickBatches/{batchId}": {
      "schema": "ChickBatch",
      "description": "User's incubation batches"
    }
  }
}
